---
---

<footer class="bg-optimist-blue text-white">
	<div class="max-w-6xl mx-auto px-6 py-10">
		<div class="md:flex md:items-start md:gap-10">

			<div class="flex-1 grid gap-10 md:grid-cols-4">

				<!-- Club -->
				<div>
					<h3 class="font-semibold text-white">Optimist Club of Mount Horeb, Wisconsin</h3>
					<p class="mt-3 text-sm text-white/80 leading-relaxed">
						Meetings: third Monday of the month, September through May, 6:45&ndash;8:00 PM<br />
						Mount Horeb Public Library
					</p>
					<p class="mt-4 text-sm text-white/70">
						Chartered 1995
					</p>
				</div>

				<!-- Get involved -->
				<div>
					<h3 class="font-semibold text-white">Get involved</h3>
					<ul class="mt-3 space-y-2 text-sm">
						<li><a href="/join" class="text-white/80 hover:text-optimist-yellow transition-colors">Join the club</a></li>
						<li><a href="/donate" class="text-white/80 hover:text-optimist-yellow transition-colors">Donate</a></li>
						<li><a href="/events" class="text-white/80 hover:text-optimist-yellow transition-colors">Events</a></li>
					</ul>
				</div>

				<!-- Connect -->
				<div>
					<h3 class="font-semibold text-white">Connect</h3>
					<ul class="mt-3 space-y-2 text-sm">
						<li><a href="https://www.facebook.com/mounthoreboptimistclub" target="_blank" rel="noopener" class="text-white/80 hover:text-optimist-yellow transition-colors">Follow us on Facebook</a></li>
						<li><a href="/newsletter" class="text-white/80 hover:text-optimist-yellow transition-colors">Newsletter</a></li>
						<li><a href="/contact" class="text-white/80 hover:text-optimist-yellow transition-colors">Contact us</a></li>
					</ul>
				</div>

				<!-- The Optimist movement -->
				<div>
					<h3 class="font-semibold text-white">The Optimist movement</h3>
					<ul class="mt-3 space-y-2 text-sm">
						<li><a href="/the-creed" class="text-white/80 hover:text-optimist-yellow transition-colors">The Optimist Creed</a></li>
						<li><a href="https://swisdistrict.org/" target="_blank" rel="noopener" class="text-white/80 hover:text-optimist-yellow transition-colors">Southern Wisconsin District</a></li>
						<li><a href="https://www.optimist.org/" target="_blank" rel="noopener" class="text-white/80 hover:text-optimist-yellow transition-colors">Optimist International</a></li>
					</ul>
				</div>

			</div>

			<!-- Logos: Mount Horeb roundel + SWIS District -->
<div class="mt-12 md:mt-4 md:flex-shrink-0 flex justify-center items-center gap-4">
  <img
    src="/images/mho-club-roundel.jpg"
    alt="Optimist Club of Mount Horeb, Wisconsin emblem"
    class="w-24 h-24 rounded-full"
    width="288"
    height="288"
  />
  <img
    src="/images/swis-district-65078.png"
    alt="SWIS District of Optimist International"
    class="w-24 h-24 object-contain"
    width="288"
    height="288"
  />
</div>

		</div>

		<div class="mt-8 pt-6 border-t border-white/20 text-xs text-white/60 text-center">
			&copy; {new Date().getFullYear()} Optimist Club of Mount Horeb, Wisconsin
		</div>
	</div>
</footer>