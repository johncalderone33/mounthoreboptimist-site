---
// NewsletterSignup.astro
// MailerLite signup form. Uses class-scoped JS so multiple instances on a page
// (or different pages) work independently. The home-page form uses ID selectors
// and lives in index.astro directly — this component is for newsletter pages.
interface Props {
	bg?: 'beige' | 'white';
}
const { bg = 'beige' } = Astro.props;
const bgClass = bg === 'white' ? 'bg-white' : 'bg-optimist-beige';
---

<section class:list={['newsletter-signup', bgClass]}>
	<div class="max-w-2xl mx-auto px-6 py-16 text-center">
		<p class="text-xs tracking-[0.3em] uppercase text-optimist-slate">Get it in your inbox</p>
		<h2 class="mt-3 text-2xl md:text-3xl font-semibold text-optimist-blue">Have next month's sent to you</h2>
		<p class="mt-6 text-lg leading-relaxed text-optimist-blue">
			Leave your email and we'll add you to the list. One short newsletter a month, on the first of the month.
		</p>

		<form
			class="mt-8 flex flex-col sm:flex-row gap-3"
			action="https://assets.mailerlite.com/jsonp/2284473/forms/185399760391243303/subscribe"
			method="post"
		>
			<input
				type="email"
				name="fields[email]"
				required
				aria-label="Email address"
				placeholder="Your email address"
				autocomplete="email"
				class="flex-1 px-4 py-3 rounded border border-optimist-slate/30 bg-white text-optimist-slate focus:outline-none focus:ring-2 focus:ring-optimist-blue"
			/>
			<input type="hidden" name="ml-submit" value="1" />
			<input type="hidden" name="anticsrf" value="true" />
			<button
				type="submit"
				class="newsletter-submit px-6 py-3 rounded bg-optimist-blue text-white font-semibold hover:bg-optimist-navy transition-colors"
			>
				Subscribe
			</button>
		</form>

		<div class="newsletter-success mt-8 hidden text-lg leading-relaxed text-optimist-blue">
			Thank you. Please check your email and click the confirmation link to finish signing up.
		</div>

		<div class="newsletter-error mt-8 hidden text-lg leading-relaxed text-red-700">
			Something went wrong. Please try again in a moment.
		</div>
	</div>
</section>

<script>
	document.querySelectorAll('.newsletter-signup').forEach((section) => {
		const form = section.querySelector('form');
		const submitBtn = section.querySelector('.newsletter-submit');
		const successMsg = section.querySelector('.newsletter-success');
		const errorMsg = section.querySelector('.newsletter-error');

		if (!(form instanceof HTMLFormElement)) return;

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			submitBtn?.setAttribute('disabled', 'true');
			if (submitBtn instanceof HTMLButtonElement) submitBtn.textContent = 'Subscribing...';
			try {
				const formData = new FormData(form);
				await fetch(form.action, { method: 'POST', body: formData, mode: 'no-cors' });
				form.classList.add('hidden');
				successMsg?.classList.remove('hidden');
			} catch (err) {
				errorMsg?.classList.remove('hidden');
				submitBtn?.removeAttribute('disabled');
				if (submitBtn instanceof HTMLButtonElement) submitBtn.textContent = 'Subscribe';
			}
		});
	});
</script>
