---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
<!-- Hero -->
<section class="bg-optimist-beige">
  <div class="max-w-4xl mx-auto px-6 py-24 md:py-32 text-center">
    <p class="italic text-3xl md:text-5xl leading-tight text-optimist-blue">
      We believe that the giving of one's self in service to our youth will advance the well-being of humankind, community, and the world.
    </p>
    <p class="mt-10 text-xs md:text-sm tracking-[0.3em] uppercase text-optimist-slate">
      Optimist Club of Mount Horeb, Wisconsin · Chartered 1995
    </p>
  </div>
</section>
<!-- Three pillars -->
<section class="bg-white">
  <div class="max-w-6xl mx-auto px-6 py-20 grid gap-12 md:grid-cols-3">
    <div>
      <h3 class="text-xl font-semibold text-optimist-blue">Invest in youth</h3>
      <p class="mt-3 text-optimist-slate leading-relaxed">
        Scholarships for graduating seniors, monthly recognition of students worth knowing, and support for the sports and activities that shape young lives.
      </p>
    </div>
    <div>
      <h3 class="text-xl font-semibold text-optimist-blue">Serve our neighbors</h3>
      <p class="mt-3 text-optimist-slate leading-relaxed">
        Supporting the Mount Horeb Summer Frolic, hosting the silent auction at the Super Bowl pancake brunch, showing up wherever Mount Horeb needs a hand.
      </p>
    </div>
    <div>
      <h3 class="text-xl font-semibold text-optimist-blue">Share fellowship</h3>
      <p class="mt-3 text-optimist-slate leading-relaxed">
        Friends who gather monthly through the school year at the Mount Horeb Public Library, sharing a moment and growing a community.
      </p>
    </div>
  </div>
</section>
<!-- Who we are -->
<section class="bg-optimist-beige">
  <div class="max-w-3xl mx-auto px-6 py-20">
    <h2 class="text-sm tracking-[0.3em] uppercase text-optimist-slate">Who we are</h2>
    <p class="mt-6 text-xl md:text-2xl leading-relaxed text-optimist-blue">
      We are friends and neighbors in Mount Horeb, Wisconsin, who believe that investing in youth is among the most important work a person can do. Once a month we meet to plan scholarships, to honor students, and to prepare for the events where Mount Horeb counts on us. The club was chartered in 1995.
    </p>
  </div>
</section>
<!-- What's coming up -->
<section class="bg-white">
  <div class="max-w-3xl mx-auto px-6 py-20">
    <h2 class="text-sm tracking-[0.3em] uppercase text-optimist-slate">What's coming up</h2>
    <h3 class="mt-6 text-2xl md:text-3xl font-semibold text-optimist-blue">Mount Horeb Summer Frolic &mdash; June 11 through 14, 2026, at Grundahl Park</h3>
    <p class="mt-6 text-lg leading-relaxed text-optimist-slate">
      Four days of carnival rides, live music, softball and volleyball tournaments, the Norsk Run, a parade, and fireworks over the park &mdash; all with a little extra this year as Mount Horeb joins the country in marking America's 250th birthday. The Optimist Club will be there all weekend, working shifts and selling raffle tickets, and we'd be glad to see you. It is our favorite weekend of the year.
    </p>
  </div>
</section>
<!-- Newsletter signup -->
<section class="bg-optimist-beige">
  <div class="max-w-3xl mx-auto px-6 py-20">
    <h2 class="text-sm tracking-[0.3em] uppercase text-optimist-slate">The newsletter</h2>
    <h3 class="mt-6 text-2xl md:text-3xl font-semibold text-optimist-blue">Meet your Mount Horeb Optimists</h3>
    <p class="mt-4 text-lg leading-relaxed text-optimist-slate">
      A short email once a month. Club news, upcoming events, and stories from around Mount Horeb. Nothing more.
    </p>

    <form
      id="newsletter-form"
      class="mt-8 flex flex-col sm:flex-row gap-3"
      action="https://assets.mailerlite.com/jsonp/2284473/forms/185399760391243303/subscribe"
      method="post"
    >
      <input
        type="email"
        name="fields[email]"
        required
        aria-label="Email address"
        placeholder="Your email address"
        autocomplete="email"
        class="flex-1 px-4 py-3 rounded border border-optimist-slate/30 bg-white text-optimist-slate focus:outline-none focus:ring-2 focus:ring-optimist-blue"
      />
      <input type="hidden" name="ml-submit" value="1" />
      <input type="hidden" name="anticsrf" value="true" />
      <button
        id="newsletter-submit"
        type="submit"
        class="px-6 py-3 rounded bg-optimist-blue text-white font-semibold hover:bg-optimist-navy transition-colors"
      >
        Subscribe
      </button>
    </form>

    <div id="newsletter-success" class="mt-8 hidden text-lg leading-relaxed text-optimist-blue">
      Thank you. Please check your email and click the confirmation link to finish signing up.
    </div>

    <div id="newsletter-error" class="mt-8 hidden text-lg leading-relaxed text-red-700">
      Something went wrong. Please try again in a moment.
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('newsletter-form');
  const submitBtn = document.getElementById('newsletter-submit');
  const successMsg = document.getElementById('newsletter-success');
  const errorMsg = document.getElementById('newsletter-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!(form instanceof HTMLFormElement)) return;

    submitBtn?.setAttribute('disabled', 'true');
    submitBtn && (submitBtn.textContent = 'Subscribing...');

    try {
      const formData = new FormData(form);
      await fetch(form.action, {
        method: 'POST',
        body: formData,
        mode: 'no-cors',
      });
      form.classList.add('hidden');
      successMsg?.classList.remove('hidden');
    } catch (err) {
      errorMsg?.classList.remove('hidden');
      submitBtn?.removeAttribute('disabled');
      submitBtn && (submitBtn.textContent = 'Subscribe');
    }
  });
</script>
<!-- Come say hello -->
<section class="bg-white">
  <div class="max-w-3xl mx-auto px-6 py-20 text-center">
    <h2 class="text-sm tracking-[0.3em] uppercase text-optimist-slate">Come say hello</h2>
    <p class="mt-6 text-xl md:text-2xl leading-relaxed text-optimist-blue">
      If you are an optimist, we would love to meet you. Be our guest &mdash; the third Monday of the month, September through May, 6:45 in the evening at the Mount Horeb Public Library. Bring a neighbor if you like. Or drop us a line and we'll share a little more about our local club.
    </p>
    <a href="/contact" class="inline-block mt-10 px-8 py-3 rounded-full bg-optimist-yellow text-optimist-blue font-semibold hover:bg-optimist-gold transition-colors">
      Say hello
    </a>
  </div>
</section>
		</main>
		<Footer />
	</body>
</html>
