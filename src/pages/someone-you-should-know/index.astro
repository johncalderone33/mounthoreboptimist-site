---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import SyskRecognitionNote from '../../components/sysk/SyskRecognitionNote.astro';
import SyskArchiveFooter from '../../components/sysk/SyskArchiveFooter.astro';
import { SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Someone You Should Know · ${SITE_TITLE}`} description="Each month, the Optimist Club of Mount Horeb, Wisconsin honors a high school student for outstanding community service." />
	</head>
	<body>
		<Header />
		<main>

<!-- Title and intro -->
<section class="bg-white">
  <div class="max-w-3xl mx-auto px-6 py-20 text-center">
    <h1 class="text-4xl md:text-5xl font-bold text-optimist-blue">Someone You Should Know</h1>
    <p class="mt-10 text-lg md:text-xl leading-relaxed text-optimist-blue">
      Every meeting, two Mount Horeb High School students join us and share their amazing stories. These are the students who help build our community. Who volunteer. Who teach and share with our younger kids, pack the food parcels, sing in the choir, stay late after practice. The kind of young person Mount Horeb quietly grows year after year.
    </p>
    <p class="mt-6 text-lg md:text-xl leading-relaxed text-optimist-blue">
      We share their story on our Facebook page, in the Mount Horeb Mail, and now here — so you can know them too.
    </p>
  </div>
</section>

<!-- Most recent month -->
<section class="bg-optimist-beige">
  <div class="max-w-3xl mx-auto px-6 py-16 text-center">
    <p class="text-sm tracking-[0.3em] uppercase text-optimist-slate">Most recently</p>
    <h2 class="mt-4 text-3xl md:text-4xl font-bold text-optimist-blue">April 2026</h2>
    <p class="mt-6 text-lg md:text-xl text-optimist-blue">Kaylen Hastings &middot; Barret Kreul</p>
    <a href="/someone-you-should-know/2026/april" class="inline-block mt-10 px-8 py-3 rounded-full bg-optimist-yellow text-optimist-blue font-semibold hover:bg-optimist-gold transition-colors">
      Meet them
    </a>
  </div>
</section>

<SyskRecognitionNote />
<SyskArchiveFooter />

		</main>
		<Footer />
	</body>
</html>